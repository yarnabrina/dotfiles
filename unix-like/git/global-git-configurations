[alias]
    a = add
    aa = add --all

    al = config --get-regexp alias

    b = branch
    bd = branch --delete
    bD = branch --delete --force
    br = branch --remote
    brv = branch --all --verbose --verbose

    co = checkout
    cob = checkout -b

    cl = clone
    clm = clone --recurse-submodules
    cls = clone --depth 1
    clsm = clone --depth 1 --recurse-submodules

    c = commit
    ca = commit --ammend
    cm = commit --message

    d = diff
    ds = diff --cached
    dw = diff HEAD
    dr = diff @{upstream}

    f = fetch --all --tags

    h = help

    lg = log --oneline
    lgp = log --pretty=format:'%Cred%h%Creset %Cgreen(%ad) %C(bold blue)<%an>%Creset %s %C(auto)%d%Creset'

    m = merge
    ma = merge --abort

    pl = pull
    plr = pull --rebase --autostash
    plnr = pull --no-rebase

    ps = push
    psf = push --force
    psu = push --set-upstream origin HEAD

    rv = remote --verbose

    rs = reset --soft
    rh = reset --hard

    sth = stash push --keep-index --include-untracked
    stp = stash pop

    st = status
    sts = status --short --branch --ahead-behind

    sw = switch
    swc = switch --create

[apply]
    # respect all whitespace differences
    ignoreWhitespace = no

    # warn and solve whitespace errors
    whitespace = fix

[branch]
    # Show most recently changed branches first.
    sort = -committerdate

[color]
    # use colour if output destination is terminal
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
    upstream = cyan

[color "diff"]
    meta = yellow
    frag = magenta bold
    func = 146 bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[core]
    # no output conversion
    attributesFile = ~/.gitattributes

    # default text editor
    editor = vim

    # global .gitignore file
    excludesFile = ~/.gitignore

    # default text viewer
    pager = diff-so-fancy | less --tabs=4 -F -R -X

    # Prevent showing files whose names contain non-ASCII symbols as unversioned.
    # http://michael-kuehnel.de/git/2014/11/21/git-mac-osx-and-german-umlaute.html
    precomposeunicode = false

    # ignoring ctime differences between the index and the working tree
    trustctime = false

    # Speed up commands involving untracked files such as `git status`.
    # https://git-scm.com/docs/git-update-index#_untracked_cache
    untrackedCache = true

    # raise for spaces before tabs and trailing whitespaces
    whitespace = -indent-with-non-tab,space-before-tab,trailing-space

[diff]
    # extending patience withlow occurrence common elements
    algorithm = histogram

    # format of amount of changes for each sub-directory
    dirstat = files,noncumulative

    # using descriptive initials instead of a/b
    mnemonicPrefix = true

    # detect copies as well as renames
    renames = copies

[difftool]
    # skip prompt before invocation
    prompt = false

[fetch]
    # recurse if superproject gets a commit that updates reference of submodule
    recurseSubmodules = on-demand

    # remove non-existing remote-tracking references
    prune = true

    # remove local tags no longer existing in remote
    pruneTags = true

    # maximum number of simultaneous fetch operations
    parallel = 0

[help]
    # suggest correction of mistyped commands
    autocorrect = prompt

[init]
    # default branch name when initializing a new repository.
    defaultBranch = main

[log]
    # abbreviate commit identifiers
    abbrevCommit = true

    # format of commit timestamp
    date = human

    # show ref names of commits
    decorate = short

    # history of single file
    follow = true

[merge]
    # include one-line descriptions from at most 20 commits
    log = true

[mergetool]
    # clean original file with conflict markers
    keepBackup = false

    # skip prompt before invocation
    prompt = false

[pull]
    # include local merge commits
    rebase = merges

[push]
    # action to take if no refspec is given
    default = upstream

    # submodules changed in revisions to be pushed are pushed
    recurseSubmodules = on-demand

[status]
    # shorter format
    short = true

    # show branch and tracking information
    branch = true

    # show commit counts with respect to upstream
    aheadBehind = true

[user]
    # name of author and committer
    name = Anirban Ray

    # email of author and committer
    email =

    # avoid guessing defaults
    useConfigOnly = true
