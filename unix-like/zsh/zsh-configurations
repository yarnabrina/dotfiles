# powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# custom settings
source $HOME/.aliases
source $HOME/.functions
source $HOME/.options
source $HOME/.bindings

# custom exports

## default editor
export VISUAL="vim"
export EDITOR="$VISUAL"

## history
export HISTFILE="$HOME/.zsh_history"  # location of history file
export HISTSIZE=10000  # amount of history in memory
export SAVEHIST=5000  # amount of history in file

## language
export LANG="en_US.UTF-8"  # setting default language
export LC_ALL="en_US.UTF-8"  # setting default encoding

## path
export PATH="$HOME/diff-so-fancy:$PATH"  # modifying system path

## word regex
export WORDCHARS=""  # bash style alpha-numeric word

# loading antigen
source $HOME/antigen.zsh
antigen init $HOME/.antigenrc

# disabling default ls outputs
zstyle ":autocomplete:*" min-input 1

# enabling powerlevel10k prompt
[[ ! -f $HOME/.p10k.zsh ]] || source $HOME/.p10k.zsh
