# create directory hierarchy and navigate
function mkcd() {
    mkdir -p $1
    cd $1
}

# fancier diff
function fdiff() {
    diff -u -t $1 $2 | diff-so-fancy
}

# shorter wrapper for `git` or `git status`
function g() {
    if [[ $# -gt 0 ]]; then
        git "$@"
    else
        git status
    fi
}

# check if command exists
function exists() {
    if ! [ -x "$(command -v $1)" ]; then
        echo "Failure: $1 not found"
        return 1
    else
        echo "Success: $(command -v $1)"
        return 0
    fi
}
