# changing directories
setopt AUTO_CD  # `cd`` is implied by providing name of directory
unsetopt CDABLE_VARS  # expanding as predeeded by `~` is skipped

# completion
setopt AUTO_LIST  # choices are listed if ambiguous
setopt AUTO_MENU  # menu completion is used if completion requested more than once
setopt AUTO_PARAM_SLASH  # insert `/` if directory name is autocompleted
setopt AUTO_REMOVE_SLASH  # auto-completed `/` is removed in case of word or command delimiters
setopt HASH_LIST_ALL  # hash full command before spelling correction
setopt LIST_AMBIGUOUS  # no choices for unambiguous completions
setopt LIST_BEEP  # return status code `1` for ambiguous completions
setopt LIST_PACKED  # show completions in columns to take less lines
unsetopt LIST_ROWS_FIRST  # list completions columnwise
setopt LIST_TYPES  # show file type identifiers
unsetopt MENU_COMPLETE  # avoid insert top match for ambiguous completions
unsetopt REC_EXACT  # avoid insert exact match for ambiguous completions

# expansion and globbing

setopt BAD_PATTERN  # print error for badly formed patterns
setopt CASE_GLOB  # case sensitive globbing
setopt EXTENDED_GLOB  # use `#`, `~`, `*` as part of patterns

# history
setopt APPEND_HISTORY  # avoid replace history
unsetopt EXTENDED_HISTORY  # avoid history timestamps
setopt HIST_EXPIRE_DUPS_FIRST  # delete duplicate history first
setopt HIST_FCNTL_LOCK  # use file lock provided by operating system
setopt HIST_FIND_NO_DUPS  # avoid display of duplicate non-contiguous history
setopt HIST_IGNORE_ALL_DUPS  # avoid duplicate history
setopt HIST_IGNORE_DUPS  # avoid duplicate of previous event
setopt HIST_LEX_WORDS  # words read from history are divided as normal CLI
unsetopt HIST_NO_FUNCTIONS  # keep function definition
setopt HIST_NO_STORE  # remove edited history
setopt HIST_REDUCE_BLANKS  # remove superfluous blanks
setopt HIST_SAVE_NO_DUPS  # avoid store duplicate history
unsetopt INC_APPEND_HISTORY  # store after shell exit
unsetopt INC_APPEND_HISTORY_TIME  # avoid history update on command finish
setopt SHARE_HISTORY  # add new typed commands to history file

# input/output
setopt ALIASES  # expand aliases
setopt CLOBBER  # allow `>` to truncate existing files
unsetopt CORRECT  # skip to attempt spelling correction
unsetopt CORRECT_ALL  # skip to attempt spelling of all arguments
setopt INTERACTIVE_COMMENTS  # allow comments
setopt RM_STAR_SILENT  #  avoid prompting before deleting with *
setopt SHORT_LOOPS  # allow short forms

# scripts and functions
unsetopt ALIAS_FUNC_DEF  # function name cannot be expanded as an alias

# shell emulation
setopt APPEND_CREATE  # no error when `>>` is used for non-existing file
unsetopt CONTINUE_ON_ERROR  # fail on error

# shell state
unsetopt SINGLE_COMMAND  # do not exit shell after just one command

# zsh line editor
unsetopt SINGLE_LINE_ZLE  # use multi-line editor
setopt ZLE  # enable zle
